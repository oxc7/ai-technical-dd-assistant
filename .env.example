# --- LLM (optional) ---
# Without a key, the app runs in mock mode and returns a high-quality sample memo,
# so the demo never breaks. Set a real key for live Claude analysis.
ANTHROPIC_API_KEY=
# Defaults to claude-opus-4-8 when unset.
ANTHROPIC_MODEL=claude-opus-4-8

# --- Knowledge base (optional) ---
# Without DATABASE_URL, the app uses an in-memory knowledge base (zero infra),
# ideal for local demos. Set this to use the Postgres + pgvector backend.
# Matches docker-compose.yml:
DATABASE_URL="postgresql://dd:dd@localhost:5432/dd_assistant?schema=public"

# --- Embeddings (optional) ---
# Without a key, embeddings use a dependency-free local fallback (demo-grade).
# Set a Voyage AI key for production-quality semantic retrieval.
VOYAGE_API_KEY=
VOYAGE_MODEL=voyage-3
